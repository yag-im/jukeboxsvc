{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: uvicorn",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "envFile": "${workspaceFolder}/.devcontainer/.env",
            "args": [
                "jukeboxsvc:create_app",
                "--factory",
                "--host",
                "${env:LISTEN_IP}",
                "--port",
                "${env:LISTEN_PORT}",
                "--reload"
            ],
            "justMyCode": false
        },
        {
            "name": "Python: gunicorn",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/.venv/bin/gunicorn",
            "envFile": "${workspaceFolder}/.devcontainer/.env",
            "args": [
                "--bind",
                "${env:LISTEN_IP}:${env:LISTEN_PORT}",
                "--worker-class",
                "uvicorn.workers.UvicornWorker",
                "--workers",
                "${env:GUNICORN_NUM_WORKERS}",
                "--timeout",
                "${env:GUNICORN_TIMEOUT}",
                "-c",
                "${workspaceFolder}/runtime/conf/gunicorn.config.py",
                "jukeboxsvc:create_app()"
            ],
            "console": "integratedTerminal",
            "justMyCode": false
        }
    ]
}
