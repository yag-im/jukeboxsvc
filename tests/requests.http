# check jukeboxsvc api

GET http://localhost/cluster/state
###

GET http://localhost/cluster/status
###

POST http://localhost/cluster/pull_image
content-type: application/json

{
    "repository": "ghcr.io/yag-im/jukebox/x11_gpu-nvidia_wine",
    "tag": "10.0"
}
###

POST http://localhost/containers/run
content-type: application/json

{
    "app_descr": {
        "slug": "the-pink-panther-hokus-pokus-pink",
        "release_uuid": "780a21c5-5635-4a6d-aece-c9267b4ac8ff",
        "platform": "win"
    },
    "reqs": {
        "app": {
            "midi": false,
            "screen_height": 480,
            "screen_width": 640
        },
        "container": {
            "runner": {
                "name": "scummvm",
                "ver": "2.9.0",
                "window_system": "x11"
            },
            "video_enc": "cpu"
        },
        "hw": {
            "gpu": "intel-uhd-p620",
            "memory": 1048576000,
            "memory_shared": null,
            "nanocpus": 1000000000
        }
    },
    "user_id": 50000,
    "preferred_dcs": ["us-west-1", "us-east-1"],
    "ws_conn": {
        "consumer_id": "e5277990-6cad-407f-bd78-646eb909a3c2",
        "id": "ws-conn-id-dev"
    }
}
